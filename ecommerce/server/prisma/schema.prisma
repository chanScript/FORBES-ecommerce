// ============================================================
// Prisma Schema — Multi-Category Ecommerce Platform
// ============================================================
// Stack: Prisma ORM + MySQL
// Features: JWT Auth, RBAC, Soft Delete, Audit Logs, Cloudinary
// Categories: Vehicles (Car, Motorcycle, Truck) + Real Estate
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Auth & RBAC
// ============================================================

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("roles")
}

model Permission {
  id          Int              @id @default(autoincrement())
  key         String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())

  @@map("permissions")
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id        String   @id @default(uuid()) @db.VarChar(36)
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  listings         Listing[]     @relation("SellerListings")
  favorites        Favorite[]
  auditLogs        AuditLog[]
  inquiries        Inquiry[]     @relation("UserInquiries")
  notifications    Notification[]

  // Soft delete tracking (who deleted/approved what)
  deletedListings  Listing[]     @relation("DeletedByListings")
  approvedListings Listing[]     @relation("ApprovedByListings")

  // Seller submission reviews
  reviewedSubmissions SellerSubmission[] @relation("ReviewedSubmissions")

  // Document reviews
  reviewedDocuments Document[] @relation("ReviewedDocuments")

  @@index([email])
  @@index([roleId])
  @@map("users")
}

// ============================================================
// Shared Enums
// ============================================================

enum ListingCategory {
  Vehicle
  RealEstate
}

enum VehicleSubtype {
  Car
  Motorcycle
  Truck
}

enum RealEstateSubtype {
  HouseAndLot
  VacantLot
  CommercialProperty
}

enum FuelType {
  Gasoline
  Diesel
  Electric
  Hybrid
  LPG
}

enum Transmission {
  Automatic
  Manual
}

enum ListingCondition {
  New
  Used
}

enum FurnishingStatus {
  Unfurnished
  SemiFurnished
  FullyFurnished
}

enum ListingStatus {
  Pending
  Approved
  Rejected
  Sold
}

// ============================================================
// Vehicle Reference Data (Brands, Models, Body Types)
// ============================================================

model Brand {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())

  models   Model[]
  listings Listing[]

  @@map("brands")
}

model Model {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  brandId   Int
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  listings Listing[]

  @@index([brandId])
  @@map("models")
}

model VehicleType {
  id   Int    @id @default(autoincrement())
  name String @unique
  slug String @unique

  listings Listing[]

  @@map("vehicle_types")
}

// ============================================================
// Listings (Multi-Category: Vehicle + Real Estate)
// ============================================================

model Listing {
  id              String           @id @default(uuid()) @db.VarChar(36)
  title           String           @db.VarChar(500)
  slug            String           @unique @db.VarChar(500)
  description     String?          @db.Text
  price           Decimal          @db.Decimal(12, 2)
  city            String           @db.VarChar(255)
  condition       ListingCondition @default(Used)
  status          ListingStatus    @default(Pending)

  // ── Category ──
  category         ListingCategory
  vehicleSubtype   VehicleSubtype?
  realEstateSubtype RealEstateSubtype?

  // ── Vehicle-specific fields (nullable — only for Vehicle category) ──
  year            Int?
  mileage         Int?
  fuelType        FuelType?
  transmission    Transmission?
  engineCapacity  Int?
  color           String?
  seats           Int?
  brandId         Int?
  brand           Brand?       @relation(fields: [brandId], references: [id])
  modelId         Int?
  model           Model?       @relation(fields: [modelId], references: [id])
  vehicleTypeId   Int?
  vehicleType     VehicleType? @relation(fields: [vehicleTypeId], references: [id])

  // ── Real Estate-specific fields (nullable — only for RealEstate category) ──
  lotArea          Decimal?          @db.Decimal(10, 2)
  floorArea        Decimal?          @db.Decimal(10, 2)
  bedrooms         Int?
  bathrooms        Int?
  parkingSpaces    Int?
  furnishingStatus FurnishingStatus?
  amenities        String?           @db.Text
  propertyAge      Int?
  titleType        String?           @db.VarChar(100)

  // ── Seller ──
  sellerId      String      @db.VarChar(36)
  seller        User        @relation("SellerListings", fields: [sellerId], references: [id])

  // ── Approval tracking ──
  approvedAt      DateTime?
  approvedBy      String?    @db.VarChar(36)
  approvedByUser  User?      @relation("ApprovedByListings", fields: [approvedBy], references: [id])
  rejectionReason String?    @db.Text

  // ── Soft delete (Trashbin) ──
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  deletedBy     String?   @db.VarChar(36)
  deletedByUser User?     @relation("DeletedByListings", fields: [deletedBy], references: [id])

  // ── Source: link to the seller submission that created this listing ──
  sourceSubmissionId Int?  @unique
  sourceSubmission   SellerSubmission? @relation("ConvertedListing", fields: [sourceSubmissionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  images    ListingImage[]
  favorites Favorite[]
  inquiries Inquiry[]
  documents Document[]     @relation("ListingDocuments")

  @@index([status])
  @@index([category])
  @@index([brandId])
  @@index([modelId])
  @@index([vehicleTypeId])
  @@index([sellerId])
  @@index([isDeleted])
  @@index([createdAt])
  @@index([price])
  @@index([year])
  @@index([city])
  @@map("listings")
}

model ListingImage {
  id        Int      @id @default(autoincrement())
  listingId String   @db.VarChar(36)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String   @db.VarChar(500)
  publicId  String   @db.VarChar(255)
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([listingId])
  @@map("listing_images")
}

// ============================================================
// Favorites (Wishlist)
// ============================================================

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    String   @db.VarChar(36)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String   @db.VarChar(36)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@map("favorites")
}

// ============================================================
// Audit Logs
// ============================================================

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    String   @db.VarChar(36)
  user      User     @relation(fields: [userId], references: [id])
  action    String   @db.VarChar(100)
  module    String   @db.VarChar(100)
  recordId  String?  @db.VarChar(36)
  ipAddress String?  @db.VarChar(45)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// Seller Submissions (Anonymous — No Account Required)
// ============================================================

enum SubmissionStatus {
  Pending
  Approved
  Rejected
}

model SellerSubmission {
  id                Int              @id @default(autoincrement())
  fullName          String           @db.VarChar(255)
  email             String           @db.VarChar(255)
  phone             String           @db.VarChar(50)
  category          ListingCategory
  vehicleSubtype    VehicleSubtype?
  realEstateSubtype RealEstateSubtype?
  propertyDetails   String           @db.Text
  price             Decimal?         @db.Decimal(12, 2)
  status            SubmissionStatus @default(Pending)
  adminNote         String?          @db.Text
  reviewedBy        String?          @db.VarChar(36)
  reviewer          User?            @relation("ReviewedSubmissions", fields: [reviewedBy], references: [id])
  reviewedAt        DateTime?

  // Link to the listing created from this submission
  convertedListing  Listing?         @relation("ConvertedListing")

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  images            SellerSubmissionImage[]
  documents         Document[]       @relation("SubmissionDocuments")

  @@index([status])
  @@index([createdAt])
  @@map("seller_submissions")
}

model SellerSubmissionImage {
  id           Int              @id @default(autoincrement())
  submissionId Int
  submission   SellerSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  url          String           @db.VarChar(500)
  publicId     String           @db.VarChar(255)
  createdAt    DateTime         @default(now())

  @@index([submissionId])
  @@map("seller_submission_images")
}

// ============================================================
// Product Inquiries (Anonymous or Authenticated)
// ============================================================

enum InquiryStatus {
  New
  Seen
  Contacted
}

model Inquiry {
  id        Int           @id @default(autoincrement())

  // Optional user (authenticated inquiries)
  userId    String?       @db.VarChar(36)
  user      User?         @relation("UserInquiries", fields: [userId], references: [id], onDelete: Cascade)

  // Anonymous contact info (always stored)
  name      String        @db.VarChar(255)
  email     String        @db.VarChar(255)
  phone     String?       @db.VarChar(50)

  listingId String        @db.VarChar(36)
  listing   Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  message   String?       @db.Text
  status    InquiryStatus @default(New)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([listingId])
  @@index([status])
  @@index([createdAt])
  @@map("inquiries")
}

// ============================================================
// Service Applications (Insurance, Finance, OR/CR, Partner)
// ============================================================

enum ApplicationStatus {
  New
  Contacted
  Closed
}

model ServiceApplication {
  id          Int               @id @default(autoincrement())
  fullName    String            @db.VarChar(255)
  email       String            @db.VarChar(255)
  address     String            @db.Text
  serviceType String            @db.VarChar(100)
  status      ApplicationStatus @default(New)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([serviceType])
  @@index([status])
  @@index([createdAt])
  @@map("service_applications")
}

// ============================================================
// Documents (Seller-Uploaded: OR/CR, Deeds, etc.)
// ============================================================

enum DocumentStatus {
  Pending
  Approved
  Rejected
}

model Document {
  id            Int             @id @default(autoincrement())
  fileName      String          @db.VarChar(255)
  fileType      String          @db.VarChar(50)
  fileSize      Int
  url           String          @db.VarChar(500)
  publicId      String          @db.VarChar(255)
  status        DocumentStatus  @default(Pending)

  // Link to a listing (authenticated sellers)
  listingId     String?         @db.VarChar(36)
  listing       Listing?        @relation("ListingDocuments", fields: [listingId], references: [id], onDelete: Cascade)

  // Link to a seller submission (public/anonymous)
  submissionId  Int?
  submission    SellerSubmission? @relation("SubmissionDocuments", fields: [submissionId], references: [id], onDelete: Cascade)

  // Review tracking
  reviewedBy    String?         @db.VarChar(36)
  reviewer      User?           @relation("ReviewedDocuments", fields: [reviewedBy], references: [id])
  reviewedAt    DateTime?
  reviewNote    String?         @db.Text

  createdAt     DateTime        @default(now())

  @@index([listingId])
  @@index([submissionId])
  @@index([status])
  @@map("documents")
}

// ============================================================
// Notifications (Admin In-App — Real-Time via Socket.io)
// ============================================================

enum NotificationType {
  NEW_LISTING
  NEW_INQUIRY
  NEW_SUBMISSION
  DOCUMENT_UPLOAD
  STATUS_CHANGE
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    String           @db.VarChar(36)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String           @db.Text
  metadata  Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================================
// System Settings (Key-Value Config Store)
// ============================================================

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
